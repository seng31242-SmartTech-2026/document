        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle\n&lt;size:16&gt;&lt;b&gt;UC-08: Checkout and Place Order - Activity Diagram&lt;/b&gt;&lt;/size&gt;\nend title\n\n|Buyer|\nstart\n\n:Navigate to Cart page and click &#39;Proceed to Checkout&#39;;\n\n|System|\n:Display order summary (items, quantities, unit prices, subtotal, delivery fee, total);\n\n|Buyer|\n:Select or enter delivery address;\n\n:Select delivery method (Standard/Express);\n\n:Review order summary and click &#39;Place Order&#39;;\n\n|System|\n:Validate stock availability for all cart items (server-side total);\n\nif (All items in stock?) then (no)\n  :Notify Buyer and highlight unavailable item(s);\n  :Buyer removes item or updates quantity;\n  :Cart preserved;\n  stop\nelse (yes)\nendif\n\n:Create Order record with status &#39;Pending Payment&#39; and reserve stock\n (multi-seller order line groups - BR-12);\n\n:Redirect Buyer to Payment Gateway (UC-09);\n\n|Buyer|\n:Complete payment (handled in UC-09);\n\n|System|\nif (Payment successful?) then (no)\n  :Order remains &#39;Pending Payment&#39; for 30 minutes;\n  :Automatically cancel order and release reserved stock (BR-14);\n  :Show payment failure message;\n  stop\nelse (yes)\nendif\n\n:Update Order status to &#39;Confirmed&#39;;\n\n:Send Order Confirmation email to Buyer and Order Notification email to Seller;\n\n:Clear shopping cart;\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="U2y3R0-jDhVh8ACwDD4h-4">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1353" width="924" x="122" y="41" as="geometry" />
          </mxCell>
